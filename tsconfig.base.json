{
	"compilerOptions": {
		"target": "ES2022",
		"module": "CommonJS",
		"moduleResolution": "Node",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"declaration": true,
		"sourceMap": true,
		"baseUrl": ".",
		"paths": {
			"@aicodebase/shared": [
				"packages/shared/src"
			],
			"@aicodebase/shared/*": [
				"packages/shared/src/*"
			]
		}
	}
}