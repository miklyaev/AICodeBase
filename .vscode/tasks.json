{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "install:all",
			"type": "shell",
			"command": "npm install",
			"problemMatcher": []
		},
		{
			"label": "dev:backend",
			"type": "shell",
			"command": "npm run dev:backend",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "dev:frontend",
			"type": "shell",
			"command": "npm run dev:frontend",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "dev:fullstack",
			"dependsOn": [
				"dev:backend",
				"dev:frontend"
			],
			"dependsOrder": "parallel",
			"problemMatcher": []
		},
		{
			"label": "dev:backend:debug",
			"type": "shell",
			"command": "npm run dev:backend:debug",
			"isBackground": true,
			"problemMatcher": {
				"owner": "typescript",
				"fileLocation": "relative",
				"pattern": {
					"regexp": "^.*$",
					"file": 1,
					"location": 2,
					"message": 3
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "ts-node-dev",
					"endsPattern": "Nest application successfully started"
				}
			}
		}
	]
}